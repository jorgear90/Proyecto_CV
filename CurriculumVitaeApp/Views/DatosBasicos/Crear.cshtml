@model CurriculumVitaeApp.Models.DatosBasicos

@{
    ViewData["Title"] = "Crear datos básicos";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="form-crear-container">
                <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
                    <h3 class="fw-bold text-dark mb-0">Nuevo dato</h3>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                        <i class="bi bi-arrow-left me-1"></i> Volver
                    </a>
                </div>
                <form asp-action="Crear" id="formCrear">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="form-group mb-3">
                        <label asp-for="NombreDato" class="control-label"></label>
                        <input asp-for="NombreDato" class="form-control" required />
                        <span asp-validation-for="NombreDato" class="text-danger"></span>
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="ValorDato" class="control-label"></label>
                        <input asp-for="ValorDato" class="form-control" required />
                        <span asp-validation-for="ValorDato" class="text-danger"></span>
                    </div>
                    <div class="form-group d-grid mt-4">
                        <input type="hidden" name="submitButton" id="submitButtonHidden" />
                        <button type="submit" onclick="confirmarCreacion(event)" class="btn btn-success btn-lg fw-bold shadow-sm">
                            <i class="bi bi-plus-circle me-2"></i> Crear antecedente
                        </button>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/vistas-crear.js"></script>
}
