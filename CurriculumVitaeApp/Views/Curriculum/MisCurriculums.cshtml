@model IEnumerable<CurriculumVitaeApp.Models.Curriculum>
@inject CurriculumVitaeApp.Helpers.IdProtector IdProtector

@{
    ViewData["Title"] = "Mis Curriculums";
}

<div class="container mt-4">
    <div class="text-center mb-4">
        <h2 class="fw-bold text-dark">Mis Currículums</h2>
        <p class="text-muted">Administra, edita o descarga tus documentos creados.</p>
    </div>

    <div class="card-configuracion">
        <div class="table-responsive">
            <table class="table custom-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>@Html.DisplayNameFor(model => model.Nombre)</th>
                        <th>@Html.DisplayNameFor(model => model.Fecha)</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center py-4 text-muted">
                                Aún no has creado ningún currículum.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr class="item-row">
                                <td class="fw-semibold text-dark">
                                    @Html.DisplayFor(modelItem => item.Nombre)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.Fecha)
                                </td>
                                <td>
                                    <div class="d-flex gap-2 justify-content-center">

                                        <a asp-action="DescargarCv"
                                           asp-route-idDescargar="@IdProtector.EncryptId(item.Id)"
                                           class="btn btn-sm btn-outline-success btn-accion"
                                           title="Descargar PDF">
                                            <i class="bi bi-download"></i>
                                        </a>

                                        <a asp-action="VistaPreviaCv"
                                           asp-route-id="@IdProtector.EncryptId(item.Id)"
                                           target="_blank" rel="noopener noreferrer"
                                           class="btn btn-sm btn-outline-info btn-accion"
                                           title="Ver vista previa">
                                            <i class="bi bi-eye-fill"></i>
                                        </a>

                                        <a asp-action="VistaSeleccionar"
                                           asp-route-idEditar="@IdProtector.EncryptId(item.Id)"
                                           class="btn btn-sm btn-outline-warning btn-accion"
                                           title="Editar datos">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>

                                        <form asp-action="EliminarCv" method="post" class="m-0">
                                            <input type="hidden" name="idEliminar" value="@IdProtector.EncryptId(item.Id)" />
                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-danger btn-accion"
                                                    onclick="confirmarEliminacion(event)"
                                                    title="Eliminar permanentemente">
                                                <i class="bi bi-trash3-fill"></i>
                                            </button>
                                        </form>

                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/vista-mis-curriculums.js"></script>
}