@model IEnumerable<CurriculumVitaeApp.Models.DatosBasicos>
@inject CurriculumVitaeApp.Helpers.IdProtector IdProtector

@{
    ViewData["Title"] = "SelectorDatosBasicos";
    Layout = null;

    var idsSeleccionados = ViewBag.IdsSeleccionados as HashSet<int> ?? new HashSet<int>();
}

<!-- Contador de seleccionados -->
<div class="d-flex justify-content-end mb-3">
    <div class="selection-counter badge">
        Seleccionados: <span class="selected-count">0</span> / <span class="total-count">@Model.Count()</span>
    </div>
</div>

<table class="table custom-table align-middle">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.NombreDato)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ValorDato)
            </th>
            <th class="text-end" style="width: 140px;">
                <div class="d-flex justify-content-end align-items-center">
                    <label class="fw-bold me-2 mb-0" for="selectAllExp" style="cursor: pointer;">Todos</label>
                    <input type="checkbox" class="form-check-input select-all m-0" id="selectAllExp" />
                </div>
            </th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr class="item-row" data-id='@IdProtector.EncryptId(item.Id)' data-tipo="1">
                <td>
                    @Html.DisplayFor(modelItem => item.NombreDato)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.ValorDato)
                </td>
                <td class="text-end">
                    <input type="checkbox" name="seleccionados" class="form-check-input chk-item" @(idsSeleccionados.Contains(item.Id) ? "checked" : "") />
                </td>
            </tr>
        }
    </tbody>
</table>
