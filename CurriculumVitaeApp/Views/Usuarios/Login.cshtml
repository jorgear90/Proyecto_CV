@model CurriculumVitaeApp.Models.Usuario

@{
    Layout = null;
    ViewData["Title"] = "Iniciar Sesión";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CurriculumApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>
<body class="auth-bg">

    <div class="auth-card">
        <h2 class="auth-title">Bienvenido</h2>

        <form asp-action="Login">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                <label asp-for="Correo" class="control-label fw-semibold text-secondary mb-1"></label>
                <input asp-for="Correo" type="email" class="form-control" placeholder="tu@correo.com" />
                <span asp-validation-for="Correo" class="text-danger small"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="Password" class="control-label fw-semibold text-secondary mb-1"></label>
                <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            @if (ViewBag.Mensaje != null)
            {
                <div class="alert alert-danger py-2 text-center small">@ViewBag.Mensaje</div>
            }

            <div class="d-grid gap-2 mb-4">
                <button type="submit" class="btn btn-primary">Ingresar</button>
            </div>

            <div class="text-center mt-3">
                <span class="text-muted">¿No tienes cuenta?</span>
                <a asp-action="Crear" class="text-decoration-none fw-bold">Regístrate aquí</a>
            </div>
        </form>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
</body>
</html>